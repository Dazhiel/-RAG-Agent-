# DashScope / Qwen
DASHSCOPE_API_KEY=your_dashscope_api_key

# Paths
DATA_DIR=data
MD5_RECORD_PATH=./runtime/md5.text

# Text splitting
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_SPLIT_THRESHOLD=500

# Retrieval
RETRIEVAL_TOP_K=3
RETRIEVAL_CANDIDATES=10
RRF_K=60

# Models
# By default, models are loaded from HuggingFace and cached under HF_HOME.
# Uncomment these two lines if you have downloaded the models locally.
# EMBEDDING_MODEL=./models/bge-m3
# RERANKER_MODEL=./models/bge-reranker-v2-m3
CHAT_MODEL=qwen3-max
SUMMARY_MODEL=qwen-turbo
DENSE_VECTOR_DIM=1024

# HuggingFace model cache, keep large local models away from C drive
HF_HOME=E:/huggingface
HF_HUB_CACHE=E:/huggingface/hub
SENTENCE_TRANSFORMERS_HOME=E:/huggingface/sentence-transformers
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_DISABLE_XET=1
# If huggingface.co is unstable in your network, uncomment this mirror.
# HF_ENDPOINT=https://hf-mirror.com

# PostgreSQL / ParadeDB
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DATABASE=rag_agent
POSTGRES_CONNECT_TIMEOUT_SECONDS=5
KNOWLEDGE_TABLE=knowledge_chunks

# Chat memory
HISTORY_RECENT_TURNS=6
DEFAULT_USER_ID=default_user

# MCP map/weather tools
MCP_ENABLED=true
MCP_TRANSPORT=http
MCP_URL=https://mcp.amap.com/mcp
AMAP_MAPS_API_KEY=your_amap_maps_api_key

# Optional public IP override
IP=

# Token report
TOKEN_COUNTER_USE_CLOUD=true
TOKEN_COUNTER_MODEL=qwen-turbo
TOKEN_COUNTER_USE_TIKTOKEN=false